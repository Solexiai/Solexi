{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    { "source": "/comprendre", "destination": "/understand/", "permanent": true },
    { "source": "/comprendre/", "destination": "/understand/", "permanent": true },
    { "source": "/comprendre.html", "destination": "/understand/", "permanent": true },

    { "source": "/problem", "destination": "/problems/", "permanent": true },
    { "source": "/problem/", "destination": "/problems/", "permanent": true },
    { "source": "/problem.html", "destination": "/problems/", "permanent": true },

    { "source": "/problemes", "destination": "/problems/", "permanent": true },
    { "source": "/problemes/", "destination": "/problems/", "permanent": true },
    { "source": "/problemes.html", "destination": "/problems/", "permanent": true },

    { "source": "/solution", "destination": "/solutions/", "permanent": true },
    { "source": "/solution/", "destination": "/solutions/", "permanent": true },
    { "source": "/solution.html", "destination": "/solutions/", "permanent": true },

    { "source": "/understand.html", "destination": "/understand/", "permanent": true },
    { "source": "/problems.html", "destination": "/problems/", "permanent": true },
    { "source": "/solutions.html", "destination": "/solutions/", "permanent": true },
    { "source": "/use-cases.html", "destination": "/use-cases/", "permanent": true },
    { "source": "/research.html", "destination": "/research/", "permanent": true },

    { "source": "/how-it-works.html", "destination": "/how-it-works/", "permanent": true },

    { "source": "/fr/vedette", "destination": "/vedette/", "permanent": true },
    { "source": "/fr/vedette/", "destination": "/vedette/", "permanent": true },
    { "source": "/fr/vedette.html", "destination": "/vedette/", "permanent": true },

    { "source": "/celebrities", "destination": "/celebrities/", "permanent": true },
    { "source": "/celebrities.html", "destination": "/celebrities/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
